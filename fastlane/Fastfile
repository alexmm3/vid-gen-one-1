default_platform(:ios)

SCHEME  = "VideoApp"
TEAM_ID = "4CB8XNCYXB"

# build_app resolves from project root, Xcodeproj from fastlane/
PROJECT_FOR_XCODEBUILD = "VideoApp.xcodeproj"
PROJECT_FOR_XCODEPROJ  = "../VideoApp.xcodeproj"

# ── Helpers ──────────────────────────────────────────────────────────
def api_key
  app_store_connect_api_key(
    key_id: ENV["APP_STORE_CONNECT_KEY_ID"] || "4HDC79WA69",
    issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"] || "45256a82-d1e5-491c-aef0-c21450002b1b",
    key_filepath: ENV["APP_STORE_CONNECT_KEY_PATH"] || ".keys/AuthKey_4HDC79WA69.p8",
    duration: 1200,
    in_house: false
  )
end

def load_env
  env_file = ".keys/appstore.env"
  if File.exist?(env_file)
    File.readlines(env_file).each do |line|
      line = line.strip
      next if line.empty? || line.start_with?("#")
      key, value = line.split("=", 2)
      ENV[key] = value unless ENV[key]
    end
  end
end

# Set CURRENT_PROJECT_VERSION in xcodeproj (works with GENERATE_INFOPLIST_FILE=YES)
def set_build_number(build_num)
  require 'xcodeproj'
  project = Xcodeproj::Project.open(PROJECT_FOR_XCODEPROJ)
  project.build_configurations.each do |config|
    config.build_settings["CURRENT_PROJECT_VERSION"] = build_num.to_s
  end
  project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings["CURRENT_PROJECT_VERSION"] = build_num.to_s
    end
  end
  project.save
  UI.success("Build number set to #{build_num}")
end

def set_marketing_version(version)
  require 'xcodeproj'
  project = Xcodeproj::Project.open(PROJECT_FOR_XCODEPROJ)
  project.build_configurations.each do |config|
    config.build_settings["MARKETING_VERSION"] = version
  end
  project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings["MARKETING_VERSION"] = version
    end
  end
  project.save
  UI.success("Marketing version set to #{version}")
end

platform :ios do

  before_all do
    load_env
  end

  # ── Build ────────────────────────────────────────────────────────
  desc "Build the app for App Store distribution"
  lane :build do |options|
    key = api_key

    # Auto-increment build number from TestFlight
    build_num = options[:build_number]
    unless build_num
      begin
        latest = latest_testflight_build_number(api_key: key)
        build_num = latest + 1
      rescue
        build_num = 1
      end
    end

    set_build_number(build_num)

    build_app(
      project: PROJECT_FOR_XCODEBUILD,
      scheme: SCHEME,
      export_method: "app-store",
      output_directory: "./build_output",
      output_name: "VideoApp.ipa",
      clean: true,
      export_options: {
        method: "app-store-connect",
        signingStyle: "manual",
        teamID: TEAM_ID,
        provisioningProfiles: {
          "com.alexm.videoeffects1" => "VideoApp AppStore Dist"
        }
      }
    )
  end

  # ── TestFlight ───────────────────────────────────────────────────
  desc "Build and upload to TestFlight"
  lane :testflight_upload do |options|
    build(build_number: options[:build_number])

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )

    UI.success("Build uploaded to TestFlight!")
  end

  # ── App Store Release ────────────────────────────────────────────
  desc "Build and submit to App Store Review"
  lane :release do |options|
    build(build_number: options[:build_number])

    upload_to_app_store(
      api_key: api_key,
      skip_screenshots: true,
      skip_metadata: options[:skip_metadata] != false,
      submit_for_review: options[:submit] || false,
      automatic_release: false,
      force: true
    )
  end

  # ── Version Bump ─────────────────────────────────────────────────
  desc "Bump version number (e.g. bump type:minor)"
  lane :bump do |options|
    require 'xcodeproj'
    project = Xcodeproj::Project.open(PROJECT_FOR_XCODEPROJ)
    current = project.build_configurations.first.build_settings["MARKETING_VERSION"] || "1.0.0"

    parts = current.split(".").map(&:to_i)
    parts << 0 while parts.length < 3

    case (options[:type] || "patch")
    when "major"
      parts = [parts[0] + 1, 0, 0]
    when "minor"
      parts = [parts[0], parts[1] + 1, 0]
    when "patch"
      parts = [parts[0], parts[1], parts[2] + 1]
    end

    new_version = parts.join(".")
    set_marketing_version(new_version)
    UI.success("Version bumped: #{current} → #{new_version}")
  end

  # ── Upload Metadata ─────────────────────────────────────────────
  desc "Upload metadata to App Store Connect"
  lane :upload_metadata do
    deliver(
      api_key: api_key,
      skip_binary_upload: true,
      skip_screenshots: false,
      force: true
    )
  end

  # ── Status ───────────────────────────────────────────────────────
  desc "Check app status in App Store Connect"
  lane :status do
    key = api_key

    begin
      build_num = latest_testflight_build_number(api_key: key)
      UI.success("Latest TestFlight build: #{build_num}")
    rescue => e
      UI.important("No TestFlight builds yet: #{e.message}")
    end
  end

end
